              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Bwalya\",\n  \"lastName\": \"Mwale\",\n  \"phone\": \"+260976543210\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
